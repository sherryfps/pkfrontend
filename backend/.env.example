# ===========================================
# PK CORPORATE ERP — BACKEND .ENV
# ===========================================

# -------------------------------------------
# SERVER
# -------------------------------------------
SERVER_PORT=9090

# -------------------------------------------
# DATABASE (PostgreSQL)
# -------------------------------------------
DB_URL=jdbc:postgresql://localhost:5432/pk_corporate
DB_USERNAME=postgres
DB_PASSWORD=vegeta@123

# -------------------------------------------
# JWT SECURITY
# -------------------------------------------
JWT_SECRET=pk-corporate-super-secret-key-minimum-256-bits-change-this-in-production
JWT_ACCESS_EXPIRY=900000
JWT_REFRESH_EXPIRY=604800000

# -------------------------------------------
# CLOUDINARY
# -------------------------------------------
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# -------------------------------------------
# EMAIL / SMTP
# -------------------------------------------
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password

# -------------------------------------------
# RAZORPAY
# -------------------------------------------
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# -------------------------------------------
# FILE UPLOAD
# -------------------------------------------
MAX_FILE_SIZE=10MB
MAX_REQUEST_SIZE=20MB

# -------------------------------------------
# FRONTEND URL (CORS)
# -------------------------------------------
FRONTEND_URL=http://localhost:3000